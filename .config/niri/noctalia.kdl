layout {

    focus-ring {
        active-color   "#80d0ff"
        inactive-color "#131313"
        urgent-color   "#ffb4ab"
    }

    border {
        active-color   "#80d0ff"
        inactive-color "#131313"
        urgent-color   "#ffb4ab"
    }

    shadow {
        color "#00000070"
    }

    tab-indicator {
        active-color   "#80d0ff"
        inactive-color "#004c6a"
        urgent-color   "#ffb4ab"
    }

    insert-hint {
        color "#80d0ff80"
    }
}

recent-windows {
    highlight {
        active-color "#80d0ff"
        urgent-color "#ffb4ab"
    }
}
